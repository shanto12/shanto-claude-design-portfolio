# Optional production target used by npm run e2e:prod and npm run verify:production.
# Parent deploy worker should set this after Netlify production deploy.
PLAYWRIGHT_BASE_URL=https://<netlify-site>.netlify.app

# Contact API does not send email or require secrets. It validates and returns
# a public-safe workflow response. Keep private phone, address, identity docs,
# compensation, recruiter details, and API keys out of this file.
